{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd web-react && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd web-react && python server.py",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

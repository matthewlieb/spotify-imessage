# SpotifiMessage Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env (it is in .gitignore). Production: set vars in the environment, not in files.

# Spotify OAuth (get from https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# Local dev:
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8004/callback
# Production: set to your backend URL, e.g. https://your-app.up.railway.app/callback

# Frontend URL (for OAuth redirects after callback)
# Local dev (Note: Spotify no longer supports 'localhost', use '127.0.0.1'):
FRONTEND_URL=http://127.0.0.1:3000
# Production: set to your frontend URL, e.g. https://yourusername.github.io/spotify-imessage

# Flask (server-side only; keep secret)
FLASK_SECRET_KEY=generate_with_openssl_rand_hex_32
FLASK_ENV=development

# React dev server (bind to all interfaces so localhost works)
HOST=0.0.0.0
BROWSER=none

# Frontend (REACT_APP_* are baked into the client bundle - never put secrets here)
REACT_APP_API_URL=http://localhost:8004
REACT_APP_API_TIMEOUT=30000

# Feature flags (optional)
REACT_APP_ENABLE_SMART_DETECTION=true
REACT_APP_ENABLE_CHAT_NAME=true
REACT_APP_ENABLE_FILE_UPLOAD=true
REACT_APP_DEBUG=false
REACT_APP_LOG_LEVEL=info

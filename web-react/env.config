# Environment Configuration for spotify-message Web App
# This file makes the app portable - you can move the directory anywhere!

# Backend API Configuration
REACT_APP_API_URL=http://localhost:8004
REACT_APP_API_TIMEOUT=30000

# Frontend Configuration  
REACT_APP_APP_NAME=spotify-message
REACT_APP_VERSION=1.0.0

# Development Settings
REACT_APP_DEBUG=false
REACT_APP_LOG_LEVEL=info

# Feature Flags
REACT_APP_ENABLE_SMART_DETECTION=true
REACT_APP_ENABLE_CHAT_NAME=true
REACT_APP_ENABLE_FILE_UPLOAD=true

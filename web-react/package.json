{
  "name": "zingaroo",
  "version": "1.0.0",
  "description": "Your friendly music-finding kangaroo that hops through your messages to discover amazing tracks",
  "private": true,
  "homepage": ".",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "axios": "^1.6.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",

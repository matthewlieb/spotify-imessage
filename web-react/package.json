{
  "name": "zingaroo",
  "version": "1.0.0",
  "description": "Your friendly music-finding kangaroo that hops through your messages to discover amazing tracks",
  "private": true,
  "homepage": ".",
  "dependencies": {
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dev-utils": "^12.0.1",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build && cp public/_redirects build/_redirects 2>/dev/null || true",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "serve": "npx serve -s build -l 3000"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [
    "spotify",
    "imessage",
    "playlist",
    "music",
    "extraction"
  ],
  "author": "Matthew Lieb",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.9.19",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18"
  }
}
